# MariaDB
# DATABASE_URL is optional/legacy. The app and Drizzle config use the explicit fields below.
# Local Docker Compose defaults:
# DATABASE_HOST=127.0.0.1
# DATABASE_PORT=3307
# DATABASE_NAME=SecureVault
# DATABASE_USER=securevault
# DATABASE_PASSWORD=securevault
DATABASE_URL=
DATABASE_HOST=
DATABASE_PORT=
DATABASE_NAME=
DATABASE_USER=
DATABASE_PASSWORD=
# Encryption Key
MASTER_ENCRYPTION_KEY=
# R2
S3_API=
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_TOKEN_VALUE=
#Stretch AI Agent
OPENAI_API_KEY=
#Email
RESEND_API_KEY=
#
NEXT_PUBLIC_APP_URL=
#Cron Secret
CRON_SECRET=
# Local development toggle to bypass Redis-backed rate limiting and upload coordination
DISABLE_REDIS=
#Redis - local Docker or any standard Redis instance
REDIS_URL=
