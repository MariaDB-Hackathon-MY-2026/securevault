#Maria Db
DATABASE_URL="mariadb://securevault:securevault@127.0.0.1:3307/SecureVault"
DATABASE_HOST="127.0.0.1"
DATABASE_NAME="SecureVault"
DATABASE_USER="securevault"
DATABASE_PASSWORD="securevault"
DATABASE_PORT=3307
# Encryption Key
MASTER_ENCRYPTION_KEY="replace_with_64_char_hex_key"
# R2
S3_API='https://<your-r2-account-id>.r2.cloudflarestorage.com'
R2_ACCOUNT_ID="<your-r2-account-id>"
R2_ACCESS_KEY_ID="<your-r2-access-key-id>"
R2_SECRET_ACCESS_KEY="<your-r2-secret-access-key>"
R2_BUCKET_NAME="secure-vault"
R2_TOKEN_VALUE='<optional-r2-token>'
#Stretch AI Agent
OPENAI_API_KEY="sk-..."
#Email
RESEND_API_KEY="re_..."
EMAIL_FROM="no-reply@example.com"
#
NEXT_PUBLIC_APP_URL="http://localhost:3000"
#Cron Secret
CRON_SECRET="cron_secret_key"
#Redis
DISABLE_REDIS="false"
REDIS_DEBUG_TIMING="true"
REDIS_URL="redis://127.0.0.1:6379"
# Semantic indexing
SEMANTIC_INDEXING_ENABLED="true"
SEMANTIC_INDEXING_EXECUTION_MODE="inline"
SEMANTIC_INDEXING_PROVIDER="google"
GEMINI_API_KEY="<your-gemini-api-key>"
GEMINI_EMBEDDING_MODEL="gemini-embedding-2-preview"
SEMANTIC_INDEXING_MAX_CONCURRENCY=2
SEMANTIC_INDEXING_MIN_SIMILARITY=0.35
SEMANTIC_INDEXING_MAX_SCORE_GAP=0.015
SEMANTIC_INDEXING_QUERY_TOP_K=50
SEMANTIC_INDEXING_MAX_RETRY_ATTEMPTS=3
SEMANTIC_INDEXING_RETRY_BACKOFF_MS=1000
PDF_FULL_EMBED_MAX_PAGES=6
PDF_WINDOW_SIZE_PAGES=6
PDF_WINDOW_OVERLAP_PAGES=1
PDF_INDEXING_MAX_BYTES=10485760
EMBEDDING_REQUEST_TIMEOUT_MS=30000

# Shared PDF image preview
SHARED_PDF_IMAGE_PREVIEW_ENABLED=true
SHARED_PDF_IMAGE_PREVIEW_MAX_BYTES=26214400
SHARED_PDF_IMAGE_PREVIEW_MAX_PAGES=100
SHARED_PDF_IMAGE_PREVIEW_DPI=144
SHARED_PDF_IMAGE_PREVIEW_MAX_PAGE_IMAGE_BYTES=2097152
SHARED_PDF_IMAGE_PREVIEW_RENDERER_PATH="C:\path\to\pdftocairo.exe"
SHARED_PDF_IMAGE_PREVIEW_RENDER_VERSION=1
