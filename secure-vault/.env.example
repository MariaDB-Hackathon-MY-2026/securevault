# MariaDB / Drizzle
# DATABASE_URL is legacy/optional. The current app and Drizzle config use the explicit DATABASE_* fields below.
DATABASE_URL=
# DATABASE_HOST: host or IP for MariaDB.
# Host-run local default: 127.0.0.1
# Containerized app default via Compose override: mariadb
DATABASE_HOST=127.0.0.1
# DATABASE_PORT: numeric MariaDB port.
# Host-run local default: 3307
# Containerized app default via Compose override: 3306
DATABASE_PORT=3307
# DATABASE_NAME: app database name.
DATABASE_NAME=SecureVault
# DATABASE_USER: database username.
DATABASE_USER=securevault
# DATABASE_PASSWORD: database password.
DATABASE_PASSWORD=securevault

# App encryption
# MASTER_ENCRYPTION_KEY is required.
# Format: 64-character hex string (32 raw bytes).
# Example generator:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
MASTER_ENCRYPTION_KEY=

# Cloudflare R2 object storage
# R2_ACCOUNT_ID: Cloudflare account ID used to build the endpoint
# https://<R2_ACCOUNT_ID>.r2.cloudflarestorage.com
R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID: R2 S3 API access key.
R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY: R2 S3 API secret key.
R2_SECRET_ACCESS_KEY=
# R2_BUCKET_NAME: target bucket name for uploads, previews, and downloads.
R2_BUCKET_NAME=
# R2_TOKEN_VALUE is reserved/legacy and not used by the current runtime code.
R2_TOKEN_VALUE=

# AI / embeddings
# SEMANTIC_INDEXING_ENABLED: enable or disable semantic indexing.
# Accepted truthy values: true, 1
# Empty or any other value disables it.
SEMANTIC_INDEXING_ENABLED=true
# SEMANTIC_INDEXING_EXECUTION_MODE options:
# - inline: process semantic jobs in the app process (documented local default, more stable)
# - queued: use Redis queue + separate worker
SEMANTIC_INDEXING_EXECUTION_MODE=inline
# SEMANTIC_INDEXING_PROVIDER options:
# - google: Gemini embeddings, requires GEMINI_API_KEY
# - fake: deterministic local fake embeddings, useful for tests/dev only
SEMANTIC_INDEXING_PROVIDER=google
# GEMINI_API_KEY: required when SEMANTIC_INDEXING_PROVIDER=google.
GEMINI_API_KEY=
# GEMINI_EMBEDDING_MODEL: optional override.
# Current documented default: gemini-embedding-2-preview
GEMINI_EMBEDDING_MODEL=gemini-embedding-2-preview
# SEMANTIC_INDEXING_MAX_CONCURRENCY: integer >= 1, default 2.
SEMANTIC_INDEXING_MAX_CONCURRENCY=2
# SEMANTIC_INDEXING_MAX_SCORE_GAP: number between 0 and 2, default 0.05.
SEMANTIC_INDEXING_MAX_SCORE_GAP=0.05
# SEMANTIC_INDEXING_MIN_SIMILARITY: number between -1 and 1, default 0.35.
SEMANTIC_INDEXING_MIN_SIMILARITY=0.35
# SEMANTIC_INDEXING_QUERY_TOP_K: integer between 25 and 200, default 50.
SEMANTIC_INDEXING_QUERY_TOP_K=50
# SEMANTIC_INDEXING_MAX_RETRY_ATTEMPTS: integer >= 0, default 3.
SEMANTIC_INDEXING_MAX_RETRY_ATTEMPTS=3
# SEMANTIC_INDEXING_RETRY_BACKOFF_MS: integer >= 100, default 1000.
SEMANTIC_INDEXING_RETRY_BACKOFF_MS=1000
# PDF_FULL_EMBED_MAX_PAGES: must be 6 for the current indexing contract.
PDF_FULL_EMBED_MAX_PAGES=6
# PDF_WINDOW_SIZE_PAGES: must be 6 for the current indexing contract.
PDF_WINDOW_SIZE_PAGES=6
# PDF_WINDOW_OVERLAP_PAGES: must be 1 for the current indexing contract.
PDF_WINDOW_OVERLAP_PAGES=1
# PDF_INDEXING_MAX_BYTES: integer > 0, default 10485760 (10 MiB).
PDF_INDEXING_MAX_BYTES=10485760
# EMBEDDING_REQUEST_TIMEOUT_MS: integer >= 1000, default 30000.
EMBEDDING_REQUEST_TIMEOUT_MS=30000

# Email
# RESEND_API_KEY: optional for local dev.
# If unset, OTP and email flows log to the server terminal instead of sending.
RESEND_API_KEY=
# EMAIL_FROM: optional sender address.
# Local fallback: onboarding@resend.dev
EMAIL_FROM=

# Public app URL
# NEXT_PUBLIC_APP_URL: browser-visible base URL used by client/server-generated links.
# Local default:
NEXT_PUBLIC_APP_URL=http://127.0.0.1:3000

# Cron auth
# CRON_SECRET: bearer token for protected cron routes such as /api/cron/cleanup and /api/cron/embeddings.
CRON_SECRET=

# Redis
# DISABLE_REDIS options:
# - empty: use REDIS_URL if configured
# - true or 1: force a no-op Redis adapter
DISABLE_REDIS=
# REDIS_URL: standard Redis connection URL.
# Local default:
REDIS_URL=redis://127.0.0.1:6379
# REDIS_DEBUG_TIMING options:
# - empty: off
# - true or 1: log Redis connection and command timing
REDIS_DEBUG_TIMING=

# Debug logging
# AUTH_DEBUG_FLOW options:
# - empty: off
# - true or 1: log auth flow debugging details
AUTH_DEBUG_FLOW=
