{
  "name": "secure-vault",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:db": "node scripts/wait-for-docker.cjs compose --file ../compose.yaml up -d mariadb",
    "dev:db:stop": "docker compose --file ../compose.yaml stop mariadb",
    "dev:redis": "node scripts/wait-for-docker.cjs compose --file ../compose.yaml up redis",
    "dev:redis:stop": "docker compose --file ../compose.yaml stop redis",
    "dev:services": "node scripts/wait-for-docker.cjs compose --file ../compose.yaml up -d mariadb redis",
    "dev:services:stop": "docker compose --file ../compose.yaml stop mariadb redis",
    "dev:host": "next dev --hostname 127.0.0.1 --port 3000",
    "build": "next build",
    "start": "next start",
    "start:host": "next start --hostname 127.0.0.1 --port 3000",
    "worker:embeddings": "tsx --tsconfig tsconfig.worker.json scripts/embedding-worker.ts",
    "benchmark:semantic": "tsx --tsconfig tsconfig.worker.json scripts/benchmark/retrieval/index.ts",
    "benchmark:semantic:pipeline": "tsx --tsconfig tsconfig.worker.json scripts/benchmark/pipeline/index.ts",
    "lint": "eslint",
    "test": "vitest run",
    "test:e2e": "playwright test --ui",
    "test:e2e:managed": "playwright test"
  },
  "dependencies": {
    "@google/genai": "^1.20.0",
    "@aws-sdk/client-s3": "^3.893.0",
    "@aws-sdk/lib-storage": "^3.1017.0",
    "@remixicon/react": "^4.9.0",
    "@tanstack/react-query": "^5.90.21",
    "@zxcvbn-ts/core": "^3.0.4",
    "argon2": "^0.44.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "drizzle-orm": "^0.45.2",
    "file-type": "^21.3.3",
    "lucide-react": "^0.577.0",
    "mysql2": "^3.19.1",
    "nanoid": "^5.1.6",
    "next": "^16.2.4",
    "next-themes": "^0.4.6",
    "pdf-lib": "^1.17.1",
    "radix-ui": "^1.4.3",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "redis": "^5.11.0",
    "resend": "^6.10.0",
    "shadcn": "^4.0.2",
    "sharp": "^0.34.5",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "use-debounce": "^10.1.0",
    "zod": "^4.3.6",
    "zxcvbn": "^4.4.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.54.2",
    "@tailwindcss/postcss": "^4",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^20.19.37",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "babel-plugin-react-compiler": "1.0.0",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "jsdom": "^28.1.0",
    "tailwindcss": "^4",
    "tsx": "^4.20.6",
    "typescript": "^5",
    "vitest": "^4.0.18"
  }
}
